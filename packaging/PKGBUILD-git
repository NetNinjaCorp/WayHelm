# Maintainer: Wayhelm contributors
#
# Builds Wayhelm from the latest commit on the default branch.
# Submit to AUR under the name `wayhelm-git`.

pkgname=wayhelm-git
_pkgname=wayhelm
pkgver=r1.0000000
pkgrel=1
pkgdesc="GUI for configuring and managing the wayvnc Wayland VNC server (git HEAD)"
arch=('x86_64')
url='https://github.com/NetNinjaCorp/WayHelm'
license=('MIT')
depends=(
  'gtk4'
  'libadwaita'
  'dbus'
  'systemd'
  'openssl'
  'iproute2'
  'wayvnc'
)
optdepends=(
  'polkit: pkexec escalation when adding firewall rules'
  'ufw: supported firewall backend'
  'firewalld: alternative firewall backend'
)
makedepends=('cargo' 'rust' 'pkgconf' 'git')
provides=("$_pkgname=$pkgver")
conflicts=("$_pkgname")
source=("$_pkgname::git+$url.git")
sha256sums=('SKIP')

pkgver() {
  cd "$_pkgname"
  # rN.<short-sha> — N = commits since beginning, sha = current HEAD.
  printf 'r%s.%s' "$(git rev-list --count HEAD)" "$(git rev-parse --short=7 HEAD)"
}

prepare() {
  cd "$_pkgname"
  export RUSTUP_TOOLCHAIN=stable
  cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
  cd "$_pkgname"
  export RUSTUP_TOOLCHAIN=stable
  export CARGO_TARGET_DIR=target
  cargo build --frozen --release
}

package() {
  cd "$_pkgname"
  install -Dm755 "target/release/$_pkgname"      "$pkgdir/usr/bin/$_pkgname"
  install -Dm644 "data/$_pkgname.desktop"        "$pkgdir/usr/share/applications/$_pkgname.desktop"
  install -Dm644 "data/io.github.wayhelm.Wayhelm.metainfo.xml" \
    "$pkgdir/usr/share/metainfo/io.github.wayhelm.Wayhelm.metainfo.xml"
  install -Dm644 "LICENSE"                       "$pkgdir/usr/share/licenses/$_pkgname/LICENSE"
}
